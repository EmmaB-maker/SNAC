        <Param val="set_up" valType="code" updates="None" name="name"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="code" plugin="None">
        <Param val="import pandas as pd&amp;#10;import random&amp;#10;from pathlib import Path&amp;#10;&amp;#10;import sys&amp;#10;import gc&amp;#10;&amp;#10;# Force garbage collection&amp;#10;gc.collect()&amp;#10;&amp;#10;# Get participant ID from experiment info&amp;#10;#pptID = expInfo['participant']&amp;#10;&amp;#10;# Define file paths&amp;#10;full_file = 'image.durations.full.xlsx'&amp;#10;equations_file = 'equations.xlsx'&amp;#10;participant_file = 'ppt.image.durations.xlsx'&amp;#10;&amp;#10;# Flag to track if we need to restart selection&amp;#10;selection_successful = False&amp;#10;max_attempts = 5  # Prevent infinite loops&amp;#10;attempt_count = 0&amp;#10;&amp;#10;while not selection_successful and attempt_count &lt; max_attempts:&amp;#10;    attempt_count += 1&amp;#10;    print(f&quot;\n--- Selection attempt {attempt_count} ---&quot;)&amp;#10;    &amp;#10;    # 1. LOAD THE FILES (fresh each attempt)&amp;#10;    df_full = pd.read_excel(full_file)&amp;#10;    df_equations = pd.read_excel(equations_file)&amp;#10;    &amp;#10;    # 2. CREATE EMPTY DATAFRAME FOR PARTICIPANT&amp;#10;    df_participant = pd.DataFrame()&amp;#10;    &amp;#10;    # 3. DEFINE ALL COMBINATIONS TO SELECT&amp;#10;    combinations = [&amp;#10;        (&quot;high arousal nature&quot;, 2.3), (&quot;high arousal nature&quot;, 3.7), &amp;#10;        (&quot;high arousal nature&quot;, 5.1), (&quot;high arousal nature&quot;, 6.5),&amp;#10;        (&quot;low arousal nature&quot;, 2.3), (&quot;low arousal nature&quot;, 3.7),&amp;#10;        (&quot;low arousal nature&quot;, 5.1), (&quot;low arousal nature&quot;, 6.5),&amp;#10;        (&quot;high arousal urban&quot;, 2.3), (&quot;high arousal urban&quot;, 3.7),&amp;#10;        (&quot;high arousal urban&quot;, 5.1), (&quot;high arousal urban&quot;, 6.5),&amp;#10;        (&quot;low arousal urban&quot;, 2.3), (&quot;low arousal urban&quot;, 3.7),&amp;#10;        (&quot;low arousal urban&quot;, 5.1), (&quot;low arousal urban&quot;, 6.5)&amp;#10;    ]&amp;#10;    &amp;#10;    # Shuffle combinations to distribute usage&amp;#10;    random.shuffle(combinations)&amp;#10;    &amp;#10;    # Track selected image names ONLY (to prevent any repeat of the same image)&amp;#10;    selected_image_names = set()&amp;#10;    &amp;#10;    # Flag to track if this attempt fails&amp;#10;    attempt_failed = False&amp;#10;    &amp;#10;    # 4. SELECT 5 ROWS FOR EACH COMBINATION&amp;#10;    for img_type, duration in combinations:&amp;#10;        available = df_full[&amp;#10;            (df_full['used'] == 'no') &amp; &amp;#10;            (df_full['type'] == img_type) &amp; &amp;#10;            (df_full['duration'] == duration)&amp;#10;        ]&amp;#10;        &amp;#10;        # Filter out any images that have already been selected (at ANY duration)&amp;#10;        available = available[~available['image_name'].isin(selected_image_names)]&amp;#10;        &amp;#10;        if len(available) &lt; 5:&amp;#10;            print(f&quot;  SHORTAGE: Only {len(available)} for {img_type}, duration {duration}. Resetting all 'used' to 'no'...&quot;)&amp;#10;            &amp;#10;            # Reset ALL 'used' values to 'no' in the full file&amp;#10;            df_full['used'] = 'no'&amp;#10;            df_full.to_excel(full_file, index=False)&amp;#10;            &amp;#10;            # Mark this attempt as failed and break out of the loop&amp;#10;            attempt_failed = True&amp;#10;            break&amp;#10;        &amp;#10;        selected = available.sample(n=5, random_state=None)&amp;#10;        df_participant = pd.concat([df_participant, selected], ignore_index=True)&amp;#10;        &amp;#10;        # Store ONLY the image names (not the durations)&amp;#10;        selected_image_names.update(selected['image_name'].tolist())&amp;#10;        print(f&quot;  Selected 5 for {img_type}, {duration}&quot;)&amp;#10;    &amp;#10;    # If we didn't fail, selection was successful&amp;#10;    if not attempt_failed:&amp;#10;        selection_successful = True&amp;#10;        print(f&quot;\nSelection successful after {attempt_count} attempt(s)!&quot;)&amp;#10;    else:&amp;#10;        print(f&quot;Attempt {attempt_count} failed, trying again...&quot;)&amp;#10;&amp;#10;# Check if we exceeded max attempts&amp;#10;if not selection_successful:&amp;#10;    raise Exception(f&quot;Could not select images after {max_attempts} attempts. Check your image database.&quot;)&amp;#10;&amp;#10;# 5. RANDOMIZE THE ORDER OF PARTICIPANT ROWS&amp;#10;df_participant = df_participant.sample(frac=1, random_state=None).reset_index(drop=True)&amp;#10;&amp;#10;# 6. RANDOMIZE EQUATIONS AND COLUMN BIND&amp;#10;df_equations_shuffled = df_equations.sample(frac=1, random_state=None).reset_index(drop=True)&amp;#10;df_equations_shuffled = df_equations_shuffled.head(len(df_participant)).reset_index(drop=True)&amp;#10;&amp;#10;for col in df_equations_shuffled.columns:&amp;#10;    df_participant[col] = df_equations_shuffled[col].values&amp;#10;&amp;#10;# 7. SAVE PARTICIPANT FILE&amp;#10;df_participant.to_excel(participant_file, index=False)&amp;#10;&amp;#10;# 8. UPDATE FULL FILE - mark selected rows as 'yes'&amp;#10;for _, row in df_participant.iterrows():&amp;#10;    mask = (df_full['image_name'] == row['image_name']) &amp; (df_full['duration'] == row['duration'])&amp;#10;    df_full.loc[mask, 'used'] = 'yes'&amp;#10;&amp;#10;df_full.to_excel(full_file, index=False)&amp;#10;&amp;#10;print(f&quot;\n{'='*50}&quot;)&amp;#10;print(f&quot;SUCCESS! Created {participant_file}&quot;)" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="True" valType="bool" updates="None" name="disabled"/>
        <Param val="code" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
